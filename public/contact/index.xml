    <item>
      <title>Contact</title>
      <link>http://localhost:1313/contact/contact/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/contact/contact/</guid>
      <description>&lt;div class=&#34;simple-contact&#34;&gt;
&lt;h2 id=&#34;-get-in-touch&#34;&gt;📧 Get in Touch&lt;/h2&gt;
&lt;form action=&#34;https://formspree.io/f/xwpvgrod&#34; method=&#34;POST&#34;&gt;
  &lt;div class=&#34;form-box&#34;&gt;
    &lt;label&gt;Your Name:&lt;/label&gt;
    &lt;input type=&#34;text&#34; name=&#34;name&#34; required&gt;
  &lt;/div&gt;
  &lt;div class=&#34;form-box&#34;&gt;
    &lt;label&gt;Your Email:&lt;/label&gt;
    &lt;input type=&#34;email&#34; name=&#34;_replyto&#34; required&gt;
  &lt;/div&gt;
  &lt;div class=&#34;form-box&#34;&gt;
    &lt;label&gt;Message:&lt;/label&gt;
    &lt;textarea name=&#34;message&#34; rows=&#34;1&#34; required&gt;&lt;/textarea&gt;
  &lt;/div&gt;
&lt;p&gt;&lt;button type=&#34;submit&#34;&gt;Send&lt;/button&gt;&lt;/p&gt;
&lt;/form&gt;
&lt;/div&gt;
&lt;hr&gt;
&lt;h3 id=&#34;-contact-info&#34;&gt;📍 Contact Info&lt;/h3&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Email:&lt;/strong&gt; &lt;a href=&#34;mailto:themskhub@gmail.com&#34;&gt;themskhub@gmail.com&lt;/a&gt;&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Location:&lt;/strong&gt; Thrissur, Kerala, India&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Social:&lt;/strong&gt;&lt;br&gt;
&lt;a href=&#34;https://instagram.com/msk_xplor&#34;&gt;Instagram&lt;/a&gt;&lt;br&gt;
&lt;a href=&#34;https://linkedin.com/in/mohammed-swalah-855b39321&#34;&gt;LinkedIn&lt;/a&gt;
&lt;a href=&#34;https://x.com/msk_swalah&#34;&gt;X&lt;/a&gt;&lt;/li&gt;
&lt;/ul&gt;
&lt;hr&gt;
&lt;script&gt;
document.querySelector(&#39;form&#39;).addEventListener(&#39;submit&#39;, async (e) =&gt; {
  e.preventDefault();
  const btn = e.target.querySelector(&#39;button&#39;);
  btn.textContent = &#39;Sending...&#39;;
  btn.disabled = true;
  
  try {
    const response = await fetch(e.target.action, {
      method: &#39;POST&#39;,
      body: new FormData(e.target),
      headers: {&#39;Accept&#39;: &#39;application/json&#39;}
    });
    
    btn.textContent = response.ok ? &#39;✓ Sent!&#39; : &#39;⚠ Error!&#39;;
    if(response.ok) e.target.reset();
  } catch {
    btn.textContent = &#39;🌐 Offline&#39;;
  }
  setTimeout(() =&gt; {
    btn.textContent = &#39;Send&#39;;
    btn.disabled = false;
  }, 2000);
});
&lt;/script&gt;</description>
